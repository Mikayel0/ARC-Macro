<Window x:Class="Macro.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Macro Control Panel" Height="500" Width="600"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E" Foreground="White">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#4A4A4A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#555555"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#222222"/>
                                <Setter Property="Foreground" Value="#555555"/>
                                <Setter Property="BorderBrush" Value="#333333"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="220" />
        </Grid.ColumnDefinitions>
        
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                <TextBlock Text="Mikayel Macro" FontSize="20" FontWeight="Bold" />
                <TextBlock Text="v1.0" FontSize="12" FontWeight="Bold" Foreground="#A0A0A0" Margin="4,6,0,0" />
            </StackPanel>

            <StackPanel Grid.Row="1" Orientation="Vertical" Margin="0,0,15,0">
                <!-- Overlay Section -->
                <TextBlock Text="Overlay Engine" FontWeight="SemiBold" Foreground="#CCCCCC" Margin="0,0,0,5"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                    <Button x:Name="ToggleOverlayBtn" Content="Start Overlay" Width="150" Height="30" HorizontalAlignment="Left" Click="ToggleOverlayBtn_Click"/>
                    <CheckBox x:Name="OverlayBorderCheck" Content="Enable Border" VerticalAlignment="Center" Foreground="#A0A0A0" Margin="10,0,0,0" Checked="SaveConfig_Changed" Unchecked="SaveConfig_Changed"/>
                </StackPanel>

                <!-- Record Section -->
                <TextBlock Text="Recording" FontWeight="SemiBold" Foreground="#CCCCCC" Margin="0,0,0,5"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                    <Button x:Name="ToggleRecordBtn" Content="Toggle Record" Width="120" Height="30" Margin="0,0,5,0" Click="ToggleRecordBtn_Click"/>
                    <Button x:Name="RebindRecordBtn" Content="Bind: [F8]" Width="80" Height="30" FontSize="11" Click="RebindRecordBtn_Click"/>
                </StackPanel>

                <!-- Playback Section -->
                <TextBlock Text="Playback" FontWeight="SemiBold" Foreground="#CCCCCC" Margin="0,0,0,5"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <Button x:Name="TogglePlayBtn" Content="Play/Stop Macro" Width="120" Height="30" Margin="0,0,5,0" Click="TogglePlayBtn_Click"/>
                    <Button x:Name="RebindPlayBtn" Content="Bind: [F9]" Width="80" Height="30" FontSize="11" Click="RebindPlayBtn_Click"/>
                </StackPanel>
                
                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                    <TextBlock Text="Speed:" VerticalAlignment="Center" Width="45" Foreground="#A0A0A0"/>
                    <Slider x:Name="SpeedSlider" Minimum="1" Maximum="10" Value="1" Width="130" Margin="0,0,5,0" VerticalAlignment="Center" IsSnapToTickEnabled="True" TickFrequency="1" AutoToolTipPlacement="TopLeft"/>
                    <TextBlock Text="{Binding Value, ElementName=SpeedSlider}" VerticalAlignment="Center" Width="20" Foreground="White" FontWeight="Bold"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <CheckBox x:Name="LoopMacroCheck" Content="Loop" VerticalAlignment="Center" Width="60" Foreground="#A0A0A0" Checked="SaveConfig_Changed" Unchecked="SaveConfig_Changed"/>
                    <TextBlock Text="Delay(ms):" VerticalAlignment="Center" Margin="0,0,5,0" Foreground="#A0A0A0"/>
                    <TextBox x:Name="LoopDelayBox" Text="1000" Width="45" Height="22" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Background="#2D2D30" Foreground="White" BorderBrush="#3F3F46" TextChanged="SaveConfig_TextChanged"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <CheckBox x:Name="SkipFirstDelayCheck" Content="Skip delay before 1st input" VerticalAlignment="Center" Foreground="#A0A0A0" Checked="SaveConfig_Changed" Unchecked="SaveConfig_Changed" Margin="0,0,10,0"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <CheckBox x:Name="SkipLastDelayCheck" Content="Skip delay before last input" VerticalAlignment="Center" Foreground="#A0A0A0" Checked="SaveConfig_Changed" Unchecked="SaveConfig_Changed"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                    <CheckBox x:Name="MuteAudioCheck" Content="Mute Arc Raiders Audio" VerticalAlignment="Center" Foreground="#A0A0A0" Margin="0,0,10,0" Checked="SaveConfig_Changed" Unchecked="SaveConfig_Changed"/>
                </StackPanel>

                <TextBlock x:Name="StatusText" Text="Status: Idle" Foreground="#A0A0A0" TextWrapping="Wrap" Margin="0,0,0,15"/>
            </StackPanel>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="SaveNameBox" Grid.Column="0" Text="" Height="30" Margin="0,0,10,0" VerticalContentAlignment="Center" Background="#2D2D30" Foreground="White" BorderBrush="#3F3F46" />
                <Button x:Name="SaveMacroBtn" Grid.Column="1" Content="Save Recorded Macro" Height="30" Width="130" IsEnabled="False" Click="SaveMacroBtn_Click"/>
            </Grid>
        </Grid>

        <Border Grid.Column="1" BorderBrush="#3F3F46" BorderThickness="1" CornerRadius="3" Background="#2D2D30" Margin="15,0,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Text="Saved Macros" FontWeight="Bold" Margin="10" />
                <ListBox x:Name="MacroListBox" Grid.Row="1" Background="Transparent" Foreground="White" BorderThickness="0" Margin="5" SelectionChanged="MacroListBox_SelectionChanged" />
                <StackPanel Grid.Row="2" Margin="10">
                    <Button x:Name="RefreshListBtn" Content="Refresh List" Height="25" Margin="0,0,0,5" Click="RefreshListBtn_Click" />
                    <Button x:Name="ClearOverlayBtn" Content="Clear Overlay" Height="25" Margin="0,0,0,5" Click="ClearOverlayBtn_Click" />
                    <Button x:Name="DeleteMacroBtn" Content="Delete Selected" Height="25" Click="DeleteMacroBtn_Click" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
